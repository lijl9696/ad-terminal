{
  "name": "pengshi-signage-windows-player",
  "version": "0.1.0",
  "private": true,
  "description": "彭世集团播放终端控制系统 Windows 播放器",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.pengshi.signage.player",
    "productName": "彭世播放终端",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../public/pengshi-logo.png",
        "to": "assets/pengshi-logo.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "../public/pengshi-logo.png",
      "artifactName": "Pengshi-Signage-Player-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "彭世播放终端"
    }
  }
}
